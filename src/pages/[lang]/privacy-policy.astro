---
import Layout from '../../layouts/Layout.astro';
import { supportedLangs, getTranslations, type Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = getTranslations(lang);
---

<Layout title={`Une Liaison | ${t.privacy.title}`} lang={lang}>
  <section class="py-24 bg-white min-h-screen w-full">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-5xl font-bold text-gray-800 mb-6 text-center">{t.privacy.title}</h1>
      <p class="text-lg text-gray-700 leading-relaxed mb-8 text-center">
        {t.privacy.last_updated}
      </p>

      <div class="prose prose-lg mx-auto text-gray-800">
        {t.privacy.sections.map((section) => (
          <>
            <h2>{section.title}</h2>
            <p>{section.text}</p>
          </>
        ))}
      </div>
    </div>
  </section>
</Layout>