---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { supportedLangs, getTranslations, type Lang } from '../../../i18n/utils';

export async function getStaticPaths() {
  const allBlog = await getCollection('blog');
  return allBlog.map(entry => {
    const slug = entry.id.replace(/(zh|ja|en)$/, '');
    const lang = entry.data.locale;
    return { params: { lang, slug }, props: { lang, slug } };
  });
}

const lang = Astro.props.lang as Lang;
const slug = Astro.params.slug as string;
const t = getTranslations(lang);
const lp = `/${lang}`;

const allBlog = await getCollection('blog');
const entry = allBlog.find(e => e.id === `${slug}${lang}` && e.data.locale === lang);

const { Content } = entry ? await render(entry) : { Content: null };
---
<Layout title={`Une Liaison | ${entry?.data.title ?? t.blog.title}`} lang={lang}>
  {entry ? (
    <section class="py-24 bg-white">
      <div class="max-w-4xl mx-auto px-4">
        <a href={`${lp}/blog`} class="inline-flex items-center text-[var(--color-primary)] hover:underline mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          {t.blog.title}
        </a>
        <h1 class="text-4xl font-bold text-gray-800 mb-4 text-center">{entry.data.title}</h1>
        <p class="text-gray-500 text-sm mb-8 text-center">
          {entry.data.date.toLocaleDateString(lang === 'en' ? 'en-US' : lang === 'ja' ? 'ja-JP' : 'zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
        {entry.data.image && (
          <img src={entry.data.image} alt={entry.data.title} class="w-full h-64 md:h-96 object-cover rounded-2xl mb-12 shadow-lg" />
        )}
        <div class="prose prose-lg mx-auto text-gray-800">
          <Content />
        </div>
      </div>
    </section>
  ) : (
    <section class="py-24 bg-white">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <h1 class="text-4xl font-bold text-gray-800 mb-8">{t.blog.title}</h1>
        <p class="text-gray-500">{t.blog.coming_soon}</p>
        <a href={`${lp}/blog`} class="text-[var(--color-primary)] hover:underline mt-8 inline-block">{t.blog.title}</a>
      </div>
    </section>
  )}
</Layout>
