---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { supportedLangs, getTranslations, type Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = getTranslations(lang);
const lp = `/${lang}`;

const allProducts = await getCollection('products');
const products = allProducts
  .filter(p => p.data.locale === lang)
  .slice(0, 4);
---

<Layout title={`Une Liaison | ${t.nav.home}`} lang={lang}>
  <section class="min-h-screen flex items-center justify-center bg-white relative overflow-hidden py-16 w-full">

    <div class="text-center px-4 relative z-10">
      <p class="text-[var(--color-primary)] font-medium tracking-widest mb-4 text-sm uppercase">{t.company.tagline}</p>
      <h1 class="text-5xl md:text-7xl font-black text-gray-800 data-[palette=harvest-dark]:text-white mb-6 leading-tight">
        Une Liaison
      </h1>
      <p class="text-xl md:text-2xl text-gray-600 data-[palette=harvest-dark]:text-gray-200 max-w-2xl mx-auto leading-relaxed">
        {t.company.slogan}
      </p>
      <div class="mt-12 flex gap-4 justify-center flex-wrap">
        <a href={`${lp}/about`} class="px-8 py-4 bg-[var(--color-primary)] text-white rounded-full font-semibold hover:opacity-90 transition-all hover:scale-105 shadow-lg hover:shadow-xl">
          {t.hero.cta_about}
        </a>
        <a href={`${lp}/products`} class="px-8 py-4 bg-[var(--color-primary)] text-white rounded-full font-semibold hover:opacity-90 transition-all hover:scale-105 shadow-lg hover:shadow-xl">
          {t.hero.cta_products}
        </a>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </section>

  <section class="py-16 bg-white data-[palette=harvest-dark]:bg-gray-800 w-full">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-gray-800 data-[palette=harvest-dark]:text-white mb-6">{t.home.story_title}</h2>
      <p class="text-lg text-gray-600 data-[palette=harvest-dark]:text-gray-200 leading-relaxed">
        {t.company.description.substring(0, 200)}...
        <a href={`${lp}/about`} class="text-[var(--color-primary)] hover:underline">{t.home.story_read_more}</a>
      </p>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-b from-white to-green-50 data-[palette=harvest-dark]:from-gray-800 data-[palette=harvest-dark]:to-gray-900 w-full">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-800 data-[palette=harvest-dark]:text-white mb-4">{t.home.products_title}</h2>
        <p class="text-lg text-gray-600 data-[palette=harvest-dark]:text-gray-200">{t.home.products_subtitle}</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {products.map((entry) => {
          const slug = entry.id.replace(/\.(zh|ja|en)$/, '');
          const features = entry.data.features || [];
          return (
            <a href={`${lp}/products/${slug}`}
               class="card-glow bg-white data-[palette=harvest-dark]:bg-gray-800 rounded-3xl p-6 shadow-lg transition-all duration-300 group block">
              <div class="text-6xl mb-4 group-hover:scale-110 transition-transform text-center">{entry.data.emoji}</div>
              <h3 class="text-xl font-bold text-gray-800 data-[palette=harvest-dark]:text-white mb-2 text-center">{entry.data.title}</h3>
              <p class="text-gray-600 data-[palette=harvest-dark]:text-gray-200 text-sm mb-4 leading-relaxed text-center">{entry.data.description}</p>
              <div class="flex flex-wrap gap-2 justify-center">
                {features[0] && (
                  <span class="px-3 py-1 bg-[var(--color-secondary)]/20 text-gray-800 data-[palette=harvest-dark]:text-gray-200 text-xs rounded-full font-medium">
                    {features[0]}
                  </span>
                )}
                {features[1] && (
                  <span class="px-3 py-1 bg-[var(--color-accent)]/20 text-gray-800 data-[palette=harvest-dark]:text-gray-200 text-xs rounded-full font-medium">
                    {features[1]}
                  </span>
                )}
              </div>
            </a>
          );
        })}
      </div>
      <div class="text-center mt-12">
        <a href={`${lp}/products`} class="px-8 py-4 bg-[var(--color-primary)] text-white rounded-full font-semibold hover:opacity-90 transition-all hover:scale-105 shadow-lg hover:shadow-xl">
          {t.home.products_cta}
        </a>
      </div>
    </div>
  </section>
</Layout>