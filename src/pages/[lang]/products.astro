---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { supportedLangs, getTranslations, type Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = getTranslations(lang);
const lp = `/${lang}`;

const allProducts = await getCollection('products');
const products = allProducts.filter(e => e.data.locale === lang);
---

<Layout title={`Une Liaison | ${t.products.title}`} lang={lang}>
  <section class="py-24 bg-gradient-to-b from-white to-green-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-16">
        <h1 class="text-5xl font-bold text-gray-800 mb-4">{t.products.title}</h1>
        <p class="text-xl text-gray-600">{t.products.subtitle}</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {products.map((entry) => {
          const title = entry.data[`title_${lang}` as keyof typeof entry.data] ?? entry.data.title;
          const description = entry.data[`description_${lang}` as keyof typeof entry.data] ?? entry.data.description;
          const features = entry.data[`features_${lang}` as keyof typeof entry.data] ?? entry.data.features;
          return (
            <a href={`${lp}/products/${entry.id.replace(/\.(zh|ja|en)\.md$/, '')}`}
               class="card-glow bg-white rounded-3xl p-6 shadow-lg transition-all duration-300 group block">
              <div class="text-6xl mb-4 group-hover:scale-110 transition-transform text-center">{entry.data.emoji}</div>
              <h3 class="text-xl font-bold text-gray-800 mb-2 text-center">{title}</h3>
              <p class="text-gray-600 text-sm mb-4 leading-relaxed text-center">{description}</p>
              <div class="flex flex-wrap gap-2 justify-center">
                {features.slice(0, 3).map((feature: string) => (
                  <span class="px-3 py-1 bg-green-100 text-[var(--color-primary)] text-xs rounded-full font-medium">
                    {feature}
                  </span>
                ))}
              </div>
              <p class="text-gray-500 text-sm leading-relaxed mt-4 text-center">{t.products.cta}</p>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</Layout>
