---
import Layout from '../../layouts/Layout.astro';
import { supportedLangs, getTranslations, type Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = getTranslations(lang);
const lp = `/${lang}`;
---

<Layout title="404 — Page Not Found" lang={lang}>
  <section class="min-h-[80vh] flex flex-col items-center justify-center text-center px-4 fade-in">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[400px] bg-[#06B6D4]/10 blur-[120px] rounded-full pointer-events-none -z-10"></div>

    <div class="relative mb-8">
      <span class="text-[150px] md:text-[200px] font-bold font-serif text-transparent bg-clip-text bg-gradient-to-br from-[#06B6D4]/30 to-[#8B5CF6]/30 select-none leading-none">404</span>
      <div class="absolute -top-4 -right-8 text-6xl animate-bounce">🔍</div>
    </div>

    <h1 class="text-2xl md:text-3xl font-bold text-[#334155] mb-4 transition-colors duration-[1200ms]">
      {t[404].title}
    </h1>
    <p class="text-[#334155]/60 mb-10 max-w-md text-lg font-light transition-colors duration-[1200ms]">
      {t[404].message}
    </p>

    <div class="flex flex-col sm:flex-row gap-4">
      <a href={`${lp}/`} class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-xl font-medium transition-all duration-[1200ms] ease-in-out bg-white/70 border border-[#334155]/20 text-[#334155] shadow-sm hover:-translate-y-1 hover:bg-[#06B6D4] hover:border-[#06B6D4] hover:text-white hover:shadow-[0_8px_20px_rgba(6,182,212,0.3)]">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
        </svg>
        {t[404].back_home}
      </a>
      <a href={`${lp}/contact`} class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-xl font-medium transition-all duration-[1200ms] ease-in-out bg-white/70 border border-[#334155]/20 text-[#334155] shadow-sm hover:-translate-y-1 hover:bg-[#8B5CF6] hover:border-[#8B5CF6] hover:text-white hover:shadow-[0_8px_20px_rgba(139,92,246,0.3)]">
        {t[404].report_issue}
      </a>
    </div>
  </section>
</Layout>

<style>
  .fade-in { animation: fadeIn 0.8s ease-out forwards; opacity: 0; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
</style>