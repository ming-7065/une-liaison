---
import Layout from '../../layouts/Layout.astro';
import { supportedLangs, getTranslations, type Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = getTranslations(lang);
---

<Layout title={`Une Liaison | ${t.about.title}`} lang={lang}>
  <section class="py-24 bg-white data-[palette=harvest-dark]:bg-gray-900">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-16">
        <h1 class="text-5xl font-bold text-gray-800 data-[palette=harvest-dark]:text-white mb-4">{t.about.title}</h1>
        <p class="text-xl text-gray-600 data-[palette=harvest-dark]:text-gray-200 max-w-3xl mx-auto">{t.about.philosophy_title}</p>
      </div>
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="card-glow bg-gradient-to-br from-green-50 to-orange-50 data-[palette=harvest-dark]:from-gray-800 data-[palette=harvest-dark]:to-gray-700 rounded-3xl p-8 md:p-12 shadow-lg">
          <h2 class="text-3xl font-bold text-[var(--color-primary)] mb-6">{t.about.philosophy_title}</h2>
          <p class="text-gray-700 data-[palette=harvest-dark]:text-gray-200 leading-relaxed mb-6">{t.about.story_p1}</p>
          <ul class="space-y-3">
            {t.about.philosophy_items.map((item) => (
              <li class="flex items-start gap-3">
                <span class="text-[var(--color-secondary)] text-xl">✓</span>
                <span class="text-gray-600 data-[palette=harvest-dark]:text-gray-200">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="space-y-8">
          <div class="card-glow bg-orange-50 data-[palette=harvest-dark]:bg-gray-700 rounded-2xl p-6 border-l-4 border-[var(--color-accent)] shadow-md">
            <h3 class="text-2xl font-bold text-gray-800 data-[palette=harvest-dark]:text-white mb-2">{t.about.values_title}</h3>
            <p class="text-gray-600 data-[palette=harvest-dark]:text-gray-200 leading-relaxed">{t.about.values_text}</p>
          </div>
          <div class="card-glow bg-green-50 data-[palette=harvest-dark]:bg-gray-700 rounded-2xl p-6 border-l-4 border-[var(--color-primary)] shadow-md">
            <h3 class="text-2xl font-bold text-gray-800 data-[palette=harvest-dark]:text-white mb-2">{t.about.advantage_title}</h3>
            <p class="text-gray-600 data-[palette=harvest-dark]:text-gray-200 leading-relaxed">{t.about.advantage_text}</p>
          </div>
          <div class="card-glow bg-yellow-50 data-[palette=harvest-dark]:bg-gray-700 rounded-2xl p-6 border-l-4 border-[var(--color-secondary)] shadow-md">
            <h3 class="text-2xl font-bold text-gray-800 data-[palette=harvest-dark]:text-white mb-2">{t.about.passion_title}</h3>
            <p class="text-gray-600 data-[palette=harvest-dark]:text-gray-200 leading-relaxed">{t.about.passion_text}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>