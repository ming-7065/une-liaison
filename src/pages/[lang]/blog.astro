---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { supportedLangs, getTranslations, type Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = getTranslations(lang);
const lp = `/${lang}`;

const allBlog = await getCollection('blog');
const blogPosts = allBlog
  .filter(e => e.data.locale === lang)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function getSlug(id: string): string {
  return id.replace(/\.(zh|ja|en)\.md$/, '');
}
---

<Layout title={`Une Liaison | ${t.blog.title}`} lang={lang}>
  <section class="py-24 bg-white min-h-screen w-full">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-5xl font-bold text-gray-800 mb-6 text-center">{t.blog.title}</h1>
      <p class="text-xl text-gray-600 leading-relaxed mb-12 text-center">
        {t.blog.subtitle}
      </p>

      <div class="grid md:grid-cols-2 gap-10">
        {blogPosts.map((entry) => (
          <article class="card-glow bg-gray-50 p-6 rounded-lg shadow-md hover:shadow-xl transition-shadow duration-300">
            <div class="bg-gradient-to-br from-[var(--color-secondary)]/10 to-[var(--color-accent)]/10 rounded-lg mb-6 w-full h-48 flex items-center justify-center text-6xl">
              {entry.data.emoji}
            </div>
            <h2 class="text-2xl font-bold text-[var(--color-primary)] mb-3">{entry.data.title}</h2>
            <p class="text-gray-500 text-sm mb-4">
              {entry.data.date.toLocaleDateString(lang === 'en' ? 'en-US' : lang === 'ja' ? 'ja-JP' : 'zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
            <p class="text-gray-700 leading-relaxed mb-4">{entry.data.excerpt}</p>
            <a href={`${lp}/blog/${getSlug(entry.id)}`} class="text-[var(--color-primary)] hover:underline">{t.blog.read_full}</a>
          </article>
        ))}
      </div>

      {blogPosts.length === 0 && (
        <p class="text-center mt-12 text-gray-500">
          {t.blog.coming_soon}
        </p>
      )}
    </div>
  </section>
</Layout>
