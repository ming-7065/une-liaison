---
interface Props {
  videoId: string;
}
const { videoId } = Astro.props;
---

<div class="video-bg-wrapper">
  <iframe
    src={`https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&mute=1&loop=1&playlist=${videoId}&controls=0&showinfo=0&rel=0&iv_load_policy=3&modestbranding=1&playsinline=1&enablejsapi=0`}
    allow="autoplay; encrypted-media"
    allowfullscreen
    loading="lazy"
    title="Background video"
  ></iframe>
</div>

<style>
.video-bg-wrapper {
  position: absolute;
  inset: 0;
  z-index: 0;
  overflow: hidden;
  background: #1a1a2e; /* fallback color while loading */
}

.video-bg-wrapper iframe {
  width: 100vw;
  height: 56.25vw; /* 16:9 */
  min-height: 100vh;
  min-width: 177.77vh;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
  border: 0;
}

@media (max-width: 767px) {
  .video-bg-wrapper iframe {
    width: 100%;
    height: 100%;
    min-width: auto;
    min-height: auto;
  }
}
</style>
